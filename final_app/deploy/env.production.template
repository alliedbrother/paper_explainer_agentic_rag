# Production Environment Configuration for AWS Deployment
# Location: /opt/ragapp/.env
#
# IMPORTANT: Replace all <placeholder> values with actual values
# For secrets, retrieve from AWS Secrets Manager: ragapp/production

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME="Agentic RAG System"
DEBUG=false

# =============================================================================
# PostgreSQL (RDS)
# =============================================================================
POSTGRES_HOST=<ragapp-db.xxxx.us-east-1.rds.amazonaws.com>
POSTGRES_PORT=5432
POSTGRES_USER=ragadmin
POSTGRES_PASSWORD=<from-secrets-manager>
POSTGRES_DB=ragdb

# =============================================================================
# Redis (ElastiCache)
# =============================================================================
REDIS_HOST=<ragapp-redis.xxxx.cache.amazonaws.com>
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if AUTH is enabled on ElastiCache

# =============================================================================
# Qdrant (Cloud - existing cluster)
# =============================================================================
QDRANT_URL=<https://your-cluster.qdrant.io>
QDRANT_API_KEY=<from-secrets-manager>
QDRANT_COLLECTION=research_papers
QDRANT_TIMEOUT=10

# =============================================================================
# OpenAI API
# =============================================================================
OPENAI_API_KEY=<from-secrets-manager>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=30.0
OPENAI_MAX_RETRIES=2

# =============================================================================
# Cohere (Reranking - Optional)
# =============================================================================
COHERE_API_KEY=<from-secrets-manager>

# =============================================================================
# LangSmith Tracing (Optional)
# =============================================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<from-secrets-manager>
# LANGCHAIN_PROJECT=agentic-rag-production

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE_FREE=3
RATE_LIMIT_TOKENS_PER_MINUTE_FREE=100
RATE_LIMIT_REQUESTS_PER_MINUTE_POWER=30
RATE_LIMIT_TOKENS_PER_MINUTE_POWER=20000
GLOBAL_RATE_LIMIT_REQUESTS_PER_MINUTE=400
GLOBAL_QUEUE_MAX_SIZE=100
GLOBAL_QUEUE_MAX_WAIT_SECONDS=60

# =============================================================================
# Response Caching
# =============================================================================
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.75
CACHE_MAX_ITEMS_PER_TENANT=25

# =============================================================================
# File Storage
# =============================================================================
PDF_STORAGE_DIR=/opt/ragapp/app/data/pdfs
MAX_FILE_SIZE_MB=50

# =============================================================================
# Agent Execution
# =============================================================================
AGENT_TIMEOUT=120.0
